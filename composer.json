{
    "name": "mauricioperera/php-a2e",
    "description": "Agent-to-Execution protocol for PHP — declarative workflow execution for AI agents",
    "type": "library",
    "license": "MIT",
    "keywords": ["ai", "agent", "a2e", "workflow", "execution", "protocol", "declarative", "rag", "neuron-ai"],
    "authors": [
        {
            "name": "Mauricio Perera",
            "homepage": "https://github.com/MauricioPerera",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/MauricioPerera/php-a2e",
    "support": {
        "issues": "https://github.com/MauricioPerera/php-a2e/issues",
        "source": "https://github.com/MauricioPerera/php-a2e"
    },
    "require": {
        "php": ">=8.1"
    },
    "suggest": {
        "mauricioperera/php-vector-store": "For RAG-based capability discovery",
        "mauricioperera/php-agent-memory": "For persistent agent memory",
        "mauricioperera/php-agent-shell": "For CLI command execution"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "PHPA2E\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPA2E\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
